TRADING_MODE=OBSERVE
TRADING_CORE_TOKEN=change-me-local-token
TRADING_DB_PATH=storage/suseok-trader-v2.sqlite3
TRADING_ALLOW_LIVE_SIM=false
TRADING_ALLOW_LIVE_REAL=false
AI_SIDECAR_ENABLED=false
AI_SIDECAR_ALLOW_INTRADAY=false
AI_SIDECAR_ALLOW_ORDER_CONTEXT=false
AI_SIDECAR_MODEL=
AI_SIDECAR_MAX_CONTEXT_CHARS=12000
AI_SIDECAR_REQUEST_TIMEOUT_SEC=30
GATEWAY_CORE_URL=http://127.0.0.1:8000
GATEWAY_CORE_TOKEN=
GATEWAY_SOURCE=mock_gateway
GATEWAY_POLL_INTERVAL_SEC=1.0
GATEWAY_HEARTBEAT_INTERVAL_SEC=2.0
GATEWAY_EVENT_TIMEOUT_SEC=5.0
GATEWAY_COMMAND_WAIT_SEC=1.0
GATEWAY_COMMAND_LIMIT=20
GATEWAY_MOCK_ONCE=false
GATEWAY_MOCK_PRICE_TICK_INTERVAL_SEC=2.0
